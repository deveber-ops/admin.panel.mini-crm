{% extends 'layouts/base.twig' %}

{% block title %}Панель управления - Продажи{% endblock %}

{% block content %}
<main class="vh-100 d-flex flex-nowrap m-3 overflow-hidden">
    {{ include('/sections/sidebar.twig') }}
    <div class="container-fluid d-flex flex-column bg-body-secondary h-100 rounded-4 p-3">
        <div class="d-flex flex-row h-100 w-100 overflow-hidden">
            <div class="d-flex flex-column w-25">
                {{ include('/sections/movementsFilter.twig') }}
                {{ include('/sections/totalSumms.twig') }}
            </div>
            <div class="d-flex flex-column overflow-hidden w-75">
                <div class="d-flex flex-column bg-body rounded-4 overflow-y-auto">
                    <div class="text-center fs-4 bg-body rounded-top-4 py-2">Движения</div>
                    <div class="row g-0 row-cols-7">
                        <div class="col-1 fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">#</span>
                        </div>
                        <div class="col-2 fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">Дата и время</span>
                        </div>
                        <div class="col fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">Основание</span>
                        </div>
                        <div class="col-2 fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">Сумма</span>
                        </div>
                        <div class="col-1 fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">Тип</span>
                        </div>
                        <div class="col-2 fs-6">
                            <span class="bg-body d-flex align-items-center justify-content-center text-center h-100 p-2">Метод</span>
                        </div>
                    </div>
                    {{ include('/sections/movementsList.twig') }}
                </div>
            </div>
        </div>
    </div>
</main>

{{ include('/sections/insertMovementModal.twig') }}
{{ include('/sections/confirmationModal.twig') }}

{% endblock %}