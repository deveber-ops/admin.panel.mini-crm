<!DOCTYPE html>
<html lang="ru">
<head>
    <!-- Базовые мета-теги -->
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="manifest" href="/manifest.json">
    
    <!-- SEO оптимизация -->
    <title>{{ SITE_NAME }} - {% block title %}{% endblock %}</title>
    <meta name="author" content="eBer">
    
    <!-- Фавиконки для всех устройств -->
    <link rel="icon" type="image/x-icon" href="/assets/images/icons/icon.svg">
    <link rel="apple-touch-icon" href="/assets/images/icons/apple-touch-icon.png">
    
    <!-- Основные CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link href="/assets/css/styles.css" rel="stylesheet">
    
    <!-- PWA настройки -->
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black">
    <meta name="apple-mobile-web-app-title" content="PROTEGO - CRM">
    <link rel="apple-touch-icon" href="/icons/icon-152x152.png">

    <!-- Предзагрузка критических ресурсов -->
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" as="style">
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" as="style">
    <link rel="preload" href="/assets/css/styles.css" as="style">
    <link rel="preload" href="/assets/js/jquery.js" as="script">
    <link rel="preload" href="/assets/js/masked.js" as="script">
    <link rel="preload" href="/assets/js/main.js" as="script">
    <link rel="preload" href="/assets/js/sw.js" as="script">
</head>
<body>
    {{ include('/sections/svg.twig') }}
    <div class="alertsGroup"></div>
    <div class="d-flex flex-column position-absolute top-0 start-0 w-100 h-100 text-bg-dark bg-opacity-50 align-items-center justify-content-center rounded-4 fade d-none" style="z-index: 9999;" id="pageLoader">
        <div class="spinner-grow" style="width: 5rem; height: 5rem;" role="status"></div>
        <span class="mt-3 fs-4">Загрузка...</span>
    </div>
    {% block content %}PROTEGO{% endblock %}
    {% if PAGE != 'login'%}{{ include('/sections/sessionModal.twig') }}{% endif %}
    <script src="/assets/js/theme.js"></script>
    <script>
        setTheme(getPreferredTheme())
        const loader = document.getElementById('pageLoader');

        loader.classList.remove('d-none'); // Показываем лоадер
        loader.classList.add('show');
    </script>
    <script src="/assets/js/sw.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.6/dist/js/bootstrap.bundle.min.js" integrity="sha384-j1CDi7MgGQ12Z7Qab0qlWQ/Qqz24Gc6BM0thvEMVjHnfYGF0rmFCozFSxQBxwHKO" crossorigin="anonymous"></script>
    <script src="/assets/js/jquery.js"></script>
    <script src="/assets/js/masked.js"></script>
    <script src="/assets/js/main.js"></script>
    <script src="/assets/js/customMenu.js"></script>
    {% if PAGE != 'login'%}<script src="/assets/js/session.js"></script>{% endif %}
</body>
</html>