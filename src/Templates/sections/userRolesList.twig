<div class="list-group rounded-top-0 border-0 rounded-bottom-0 overflow-y-auto full-scroll px-1 bg-body" id="userRolesList">
{% if ROLES is empty %}
    <div class="list-group-item d-flex flex-row p-2 text-center">Ни одной группы пользователей еще не добавлено.</div>
{% endif %}

{% for ROLE in ROLES %}
<div class="list-group-item d-flex flex-row p-1 border-0 bg-body-secondary rounded-4 mb-1" data-action="Role" data-form="updateRole" data-update="userRolesList" data-id="{{ROLE.id}}" data-name="{{ROLE.name}}" data-code="{{ROLE.code}}" data-description="{{ROLE.description}}">
    <button type="button" class="list-group-item list-group-item-action d-flex flex-row border-0 text-wrap text-break rounded-4 p-1 px-2 sortBtn" sort-id="{{ROLE.id}}" sort-action="usersList" onclick="sortItems(this)" aria-current="true">
        <span class="badge rounded-pill text-bg-info p-2 my-auto text-center me-2" style="min-width: 2rem;">{{ROLE.user_count}}</span>
        <div class="d-flex flex-column align-items-between">
            <span class="fw-medium {% if ROLE.description != ''%}mb-2{% endif %}">{{ROLE.name}} ({{ROLE.code}})</span>
            <small class="">{{ROLE.description}}</small>
        </div>
    </button>
</div>
{% endfor %}
</div>