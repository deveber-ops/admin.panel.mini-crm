<div class="list-group rounded-top-0 border-0 rounded-bottom-0 overflow-y-auto full-scroll px-1 bg-body" id="categoriesList">
    {% if CATEGORIES is empty %}
        <div class="list-group-item d-flex flex-row p-2 text-center">Категории еще не добавлены.</div>
    {% endif %}

    {% for CAT in CATEGORIES %}
    <div class="list-group-item d-flex flex-row p-1 border-0 bg-body-secondary rounded-4 mb-1" data-action="Category" data-form="updateCategory" data-update="categoriesList" data-id="{{CAT.id}}" data-name="{{CAT.name}}">
        <button type="button" class="list-group-item list-group-item-action border-0 text-wrap text-break rounded-4 p-2 sortBtn" sort-id="{{CAT.id}}" sort-action="servicesList" onclick="sortItems(this)" aria-current="true">
        {{CAT.name}}
        </button>
    </div>
    {% endfor %}
</div>