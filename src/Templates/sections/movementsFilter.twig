<button class="btn btn-secondary btn-lg d-flex flex-row align-items-center justify-content-between dropdown-toggle p-2 rounded-4 me-3 mb-2" type="button" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside">
    <svg class="icon-2 me-2"><use xlink:href="#sliders"></use></svg> <span class="me-2">Фильтр</span>
</button>
<ul class="dropdown-menu p-3 rounded-4" id="movementsFilter">
    <li><h6 class="dropdown-header text-center text-bg-secondary rounded-4 mb-3">Фильтр</h6></li>
    <form class="d-flex flex-column" action="filterMovements" data-update="movementsList, totalSumms" name="filterMovements" id="filterMovements">
        <div class="d-flex flex-row">
            <div class="d-flex flex-column me-2 w-50">
                <span class="w-100 text-center mb-1">Дата начало</span>
                <div class="input-group input-group-sm">
                    <input type="date" class="form-control rounded-4 text-center fw-normal" name="start_date">
                </div>
            </div>
            <div class="d-flex flex-column w-50">
                <span class="w-100 text-center mb-1">Дата конец</span>
                <div class="input-group input-group-sm">
                    <input type="date" class="form-control rounded-4 text-center fw-normal" name="end_date">
                </div>
            </div>
        </div>
        <span class="w-100 text-center mb-1 mt-2">Тип движения</span>
        <div class="input-group mt-2">
            <select class="form-select" name="type">
                <option value="Все" selected>Все</option>
                <option value="Приход">Приход</option>
                <option value="Расход">Расход</option>
            </select>
        </div>
        <span class="w-100 text-center mb-1 mt-2">Основание</span>
        <div class="input-group mt-2">
            <input list="footings-list" placeholder="Основание" class="form-control" name="footing" autocomplete="off" required>
            <datalist id="footings-list">
                {% for FOOTING in FOOTINGS %}
                <option value="{{FOOTING.value}}">
                {% endfor %}
            </datalist>
        </div>
        <span class="w-100 text-center mb-1">Метод</span>
        <div class="row row-cols-auto mb-3">
            <div class="col">
                {% for METHOD in PAYMETHODS %}
                <input type="radio" class="btn-check" name="method" value="{{METHOD.id}}" id="method-{{METHOD.id}}" autocomplete="off">
                <label class="btn btn-sm btn-outline-secondary text-uppercase" for="method-{{METHOD.id}}">{{METHOD.name}}</label>
                {% endfor %}
            </div>
        </div>
        <button type="button" class="btn btn-warning rounded-4 mt-4" id="resetForm">Сбросить</button>
    </form>
</ul>