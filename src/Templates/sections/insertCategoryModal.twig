<div class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" id="insertCategoryModal" tabindex="-1" aria-labelledby="insertCategoryModalLabel">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4">
      <div class="modal-header p-2 justify-content-center border-0">
        <h1 class="modal-title fs-5" id="insertCategoryLabel">Добавить категорию</h1>
      </div>
      <div class="modal-body py-2">
        <form action="insertCategory" updateSections="categoriesList, insertServiceModal, updateServiceModal" class="row g-3 needs-validation" name="insertCategory" id="insertCategory" novalidate>
          <div class="input-group">
            <span class="input-group-text" id="basic-addon1">Наименование</span>
            <input type="text" class="form-control" name="name" required>
          </div>
        </form>
      </div>
      <div class="modal-footer p-2 border-0 justify-content-between">
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Отмена</button>
        <button type="submit" form="insertCategory" class="btn btn-success">Добавить</button>
      </div>
    </div>
  </div>
</div>