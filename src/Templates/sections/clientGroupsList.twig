<div class="list-group rounded-top-0 border-0 rounded-bottom-0 overflow-y-auto full-scroll px-1 bg-body" id="clientGroupsList">
    {% if GROUPS is empty %}
        <div class="list-group-item d-flex flex-row p-2 text-center">Группы еще не добавлены.</div>
    {% endif %}

    {% for GROUP in GROUPS %}
    <div class="list-group-item d-flex flex-row p-1 border-0 bg-body-secondary rounded-4 mb-1" data-action="ClientGroup" data-form="updateClientGroup" data-update="clientGroupsList" data-id="{{GROUP.id}}" data-name="{{GROUP.name}}" data-discount="{{GROUP.discount}}">
        <button type="button" class="list-group-item list-group-item-action d-flex align-items-center border-0 text-wrap text-break rounded-4 p-1 px-2 sortBtn" sort-id="{{GROUP.id}}" sort-action="clientsList" onclick="sortItems(this)" aria-current="true">
        <span class="badge rounded-pill text-bg-info p-2 my-auto text-center me-2" style="min-width: 2rem;">{{GROUP.clients_count}}</span>
        {{GROUP.name}} <span class="badge rounded-pill text-bg-info ms-auto">{{GROUP.discount}}%</span>
        </button>
    </div>
    {% endfor %}
</div>