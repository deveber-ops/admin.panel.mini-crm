<div class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" id="updateMovementModal" tabindex="-1" aria-labelledby="updateMovementModalLabel">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4">
      <div class="modal-header p-2 justify-content-center border-0">
        <h1 class="modal-title fs-5" id="updateMovementLabel">Добавить движение</h1>
      </div>
      <div class="modal-body py-2">
        <form action="updateMovement" updateSections="movementsList, movementsFilter" class="row g-3 needs-validation" name="updateMovement" id="updateMovement" novalidate>
            <input type="hidden" class="form-control" name="id" required>
            <div class="input-group mb-2">
                <select class="form-select" name="type" required>
                    <option value="Расход" selected>Расход</option>
                    <option value="Приход">Приход</option>
                </select>
                <span class="input-group-text">Сумма</span>
                <input type="number" step="0.01" min="1" value="" class="form-control" name="summ" required>
            </div>
            <div class="input-group mt-0">
                <input list="footings-list" placeholder="Основание" class="form-control" name="footing" autocomplete="off" required>
                <datalist id="footings-list">
                    {% for FOOTING in FOOTINGS %}
                    <option value="{{FOOTING.value}}">
                    {% endfor %}
                </datalist>
            </div>
            <div class="btn-group btn-group-lg w-100">
                {% for METHOD in PAYMETHODS %}
                    {% if METHOD.code != 'mixed' %}
                    <input type="radio" class="btn-check w-100 h-100" name="pay_method" data-code="{{METHOD.code}}" value="{{METHOD.id}}" id="payMethod{{METHOD.code}}" autocomplete="off" {% if loop.first %} required {% endif %}>
                    <label class="btn btn-outline-secondary py-3 text-uppercase" for="payMethod{{METHOD.code}}">{{METHOD.name}}</label>
                    {% endif %}
                {% endfor %}
            </div>
        </form>
      </div>
      <div class="modal-footer p-2 border-0 justify-content-between">
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">Отмена</button>
        <button type="submit" form="updateMovement" class="btn btn-success">Добавить</button>
      </div>
    </div>
  </div>
</div>