<ol class="list-group bg-body px-1 rounded-top-0 border-bottom-0 rounded-bottom-0 h-100 overflow-y-auto full-scroll" id="servicesList">
{% if SERVICES is empty %}
    <div class="list-group-item d-flex flex-row p-2 text-center">Услуги еще не добавлены.</div>
{% endif %}

{% for SERVICE in SERVICES %}
    <ul class="list-group list-group-horizontal mb-1 w-100 rounded-4" data-action="Service" data-update="servicesList" data-form="updateService" data-id="{{SERVICE.id}}" data-category-id="{{SERVICE.category_id}}" data-category-name="{{SERVICE.category_name}}" data-name="{{SERVICE.name}}" data-price="{{SERVICE.price}}" data-completion="{{SERVICE.completion_time}}" data-warranty="{{SERVICE.warranty_days}}" data-description="{{SERVICE.description}}">
        <li class="list-group-item d-flex align-items-center justify-content-center fw-light text-wrap px-1 rounded-start-4 border-0 bg-body-secondary" style="min-width: 10rem; max-width: 10rem;">{{ SERVICE.category_name }}</li>
        <li class="list-group-item d-flex flex-row px-1 w-100 border-0 bg-body-secondary align-items-center">
            <span class="fw-medium">{{ SERVICE.name }}</span>
        </li>
        <li class="list-group-item px-1 d-flex align-items-center justify-content-center fw-medium border-0 bg-body-secondary" style="min-width: 7rem;">{{ SERVICE.price }} BYN</li>
        <li class="list-group-item px-1 d-flex align-items-center justify-content-center border-0 bg-body-secondary" style="min-width: 10rem;">Гарантия: {{ SERVICE.warranty_days }} дн.</li>
        <li class="list-group-item px-1 d-flex align-items-center justify-content-center fw-medium border-0 bg-body-secondary" style="min-width: 7rem;">{{ SERVICE.completion_time }} мин.</li>
        <li class="list-group-item px-1 rounded-end-4 d-flex flex-row align-items-center border-0 bg-body-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="rounded-circle me-4" viewBox="0 0 16 16" data-bs-toggle="popover" data-bs-trigger="hover focus click" data-bs-content='{{ SERVICE.description }}'>
                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/>
            </svg>
            {# <button type="button" class="btn btn-outline-secondary p-1" data-bs-toggle="modal" data-bs-target="#updateServiceModal" updateSections="servicesList" form="updateService" service-id="{{SERVICE.id}}" category-id="{{SERVICE.category_id}}" category-name="{{SERVICE.category_name}}" service-name="{{SERVICE.name}}" service-price="{{SERVICE.price}}" service-warranty="{{SERVICE.warranty_days}}" service-completion-time="{{SERVICE.completion_time}}" service-description="{{SERVICE.description}}" onclick="updateElements(this)"><svg class="icon-1"><use xlink:href="#pencil-square"/></svg></button>
            <button type="button" class="btn btn-outline-danger p-1" data-bs-toggle="modal" data-bs-target="#confirmationModal" confirm="removeService" service-id="{{SERVICE.id}}" service-name="{{SERVICE.name}}" category-name="{{SERVICE.category_name}}" onclick="confirmationModal(this)"><svg class="icon-1"><use xlink:href="#trash"/></svg></button> #}
        </li>
    </ul>
{% endfor %}
</ol>