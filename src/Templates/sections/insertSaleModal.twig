<div class="modal fade" data-bs-backdrop="static" data-bs-keyboard="false" id="insertSaleModal" tabindex="-1" aria-labelledby="insertSaleLabel">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content rounded-4 position-relative">
      <div class="d-flex flex-column position-absolute top-0 start-0 w-100 h-100 text-bg-info bg-opacity-50 align-items-center justify-content-center rounded-4 fade d-none" style="z-index: 9999;" id="waitPaid">
        <div class="spinner-grow" style="width: 5rem; height: 5rem;" role="status"></div>
        <span class="mt-3 fs-4">Ожидание оплаты...</span>
      </div>
      <div class="modal-header p-2 justify-content-center border-0">
        <h1 class="modal-title fs-5" id="insertSaleLabel">Добавить продажу</h1>
      </div>
      <div class="modal-body py-2">
        <form action="insertSale" updateSections="salesList" class="row g-2 needs-validation" name="insertSale" id="insertSale" novalidate>
          <div class="col-5 ms-auto">
            <div class="input-group input-group-lg mb-2">
              <input type="text" class="form-control" name="executor_name" value="{{USERNAME}}" readonly required>
              <input type="hidden" class="form-control" name="executor_id" value="{{USERID}}" readonly required>
              <span class="input-group-text" id="datetime">Исполнитель</span>
            </div>
          </div>
          <h5 class="w-100 text-center m-0">Клиент</h5>
          <div class="col-6">
            <div class="input-group input-group-lg mb-2">
              <span class="input-group-text" id="service">Телефон</span>
              <input type="tel" class="form-control" name="phone" required>
            </div>
          </div>
          <div class="col-6">
            <div class="input-group input-group-lg mb-2">
              <span class="input-group-text" id="service">Имя</span>
              <input type="text" class="form-control" name="name" placeholder="Имя" required>
            </div>
          </div>
          <ul class="list-group list-group-horizontal w-100 justify-content-center d-none" id="clientInfo">
            <li class="list-group-item" id="clientTotalSales"></li>
            <li class="list-group-item" id="clientLastSale"></li>
            <li class="list-group-item" id="clientPersonalDiscount"></li>
          </ul>
          <div class="container p-2 mt-3 rounded-top bg-body-secondary" id="saleServiceForms">
            <div class="row g-2" id="serviceForm" data-id="1">
              <select id="service" class="form-select w-50 d-none" name="services[1][id]" data-id="1" required>
                {% for SERVICE in SERVICES %}
                  <option value="{{ SERVICE.id }}" data-price="{{ SERVICE.price }}">{{ SERVICE.name }}</option>
                {% endfor %}
              </select>
              <div class="col-9">
                <div class="input-group input-group-lg">
                  <span class="input-group-text" id="service">Услуга</span>
                  <input type="button" class="form-select text-start w-50 serviceSelect text-wrap" data-bs-auto-close="outside" data-id="1" data-bs-toggle="dropdown" aria-expanded="false" readonly>
                  <ul class="dropdown-menu p-2 categoriesDropdown" data-id="1">
                    {% for CAT in CATEGORIES %}
                    <div class="dropend serviceDropdown">
                      <button type="button" class="btn btn-outline-secondary border-0 text-nowrap d-flex justify-content-between align-items-center w-100 {% if not loop.last %}mb-1{% endif %}" data-bs-toggle="dropdown" aria-expanded="false">{{CAT.name}} <svg class="icon-1"><use xlink:href="#caret-right-fill"/></svg></button>
                      <ul class="dropdown-menu p-0">
                        <div class="list-group list-group-flush">
                          <div class="d-flex justify-content-center my-2">{{CAT.name}}</div>
                          {% for SERVICE in SERVICES %}
                          {% if CAT.id == SERVICE.category_id %}
                            <button type="button" class="list-group-item list-group-item-action text-nowrap d-flex justify-content-between" data-id="1" data-serviceid="{{SERVICE.id}}" data-category="{{SERVICE.category_name}}" data-name="{{SERVICE.name}}" data-price="{{SERVICE.price}}" onclick="setServiceInSelect(this)">{{SERVICE.name}} <span class="ms-4 ps-4 border-start">{{SERVICE.price}} BYN</span> </button>
                          {% endif %}
                          {% endfor %}
                        </div>
                      </ul>
                    </div>
                    {% endfor %}
                  </ul>
                  <input type="number" class="form-control text-center fs-5" data-id="1" name="services[1][price]" value="0" readonly required>
                  <span class="input-group-text" id="service">BYN</span>
                </div>
              </div>
              <div class="col-3">
                <div class="input-group input-group-lg h-100">
                  <span class="input-group-text" id="service" data-id="1">Скидка</span>
                  <input type="number" class="form-control" placeholder="%" min="0" max="100" step="1" data-id="1" name="services[1][discount]" oninput="sumAllServices()">
                </div>
              </div>
              <div class="col-12">
                <div class="input-group input-group-lg">
                  <span class="input-group-text" id="service">Устройство</span>
                  <input type="text" class="form-control rounded-end" name="services[1][device]" data-id="1" required>
                  <button type="button" class="btn btn-secondary rounded ms-2" data-id="1" onclick="clearDevice(this)">Очистить</button>
                  <button type="button" class="btn btn-danger rounded ms-2 d-none" data-action="remove" data-id="1" onclick="removeServiceForm(this)"><svg class="icon-1"><use xlink:href="#trash"/></svg></button>
                </div>
              </div>
            </div>
          </div>
          <div class="row m-0 p-2 bg-body-secondary rounded-bottom border-top">
            <div class="col-7 m-0 p-0">
              <div class="btn-group btn-group-lg w-100">
                {% for METHOD in PAYMETHODS %}
                <input type="radio" class="btn-check w-100 h-100" name="pay_method" data-code="{{METHOD.code}}" value="{{METHOD.id}}" id="payMethod{{METHOD.code}}" autocomplete="off" {% if loop.first %} required {% endif %}>
                <label class="btn btn-outline-secondary py-3 text-uppercase" for="payMethod{{METHOD.code}}">{{METHOD.name}}</label>
                {% endfor %}
              </div>
              <div class="input-group input-group-lg px-3 d-none" id="mixedInputs">
                <span class="input-group-text border-top-0 rounded-top-0" id="service">Наличными</span>
                <input type="number" min="0.1" step="0.01" value="0.00" class="form-control border-top-0" name="cash" oninput="mixedPaymenth(this)">
                <input type="number" min="0.1" step="0.01" value="0.00" class="form-control border-top-0" name="card" oninput="mixedPaymenth(this)">
                <input type="hidden" min="0.1" step="0.01" value="0.00" class="form-control border-top-0" name="noncash">
                <span class="input-group-text border-top-0 rounded-top-0" id="service">Картой</span>
              </div>
            </div>
            <div class="col-5 m-0 p-0">
              <div class="input-group input-group-lg ms-auto ps-2 pt-0">
                <span class="input-group-text" id="service">СУММА</span>
                <input type="number" step="0.01" inputmode="decimal" class="form-control rounded-end py-3 fs-5" name="summ" required readonly>
                <button type="button" class="btn btn-warning ms-2 rounded" data-id="1" onclick="insertServiceInSaleForm(this)">Добавить услугу</button>
              </div>
              <div class="form-check d-flex align-items-center ms-2">
                <input class="form-check-input" type="checkbox" id="checkReceipt" name="receiptCheck">
                <label class="form-check-label ms-2" for="checkReceipt">
                  Выдать чек
                </label>
                <input class="form-check-input" type="hidden" value="false" name="receipt">
              </div>
            </div>
          </div>
        </form>
      </div>
      <div class="modal-footer p-2 border-0 justify-content-between">
        <button type="button" class="btn btn-lg btn-danger" data-bs-dismiss="modal">Отмена</button>
        <button type="submit" form="insertSale" class="btn btn-lg btn-success">Отправить</button>
      </div>
    </div>
  </div>
</div>