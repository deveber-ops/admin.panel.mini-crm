{% extends 'layouts/mailBase.twig' %}

{% block content %}
<table width="100%" border="0" cellspacing="0" cellpadding="0">
    <!-- Шапка с логотипом -->
    <tr>
        <td align="center" style="padding: 30px 0;">
            <img src="{{ BASE_URL }}/assets/images/icons/logo.png" alt="PROTEGO" width="180" style="display: block;">
        </td>
    </tr>
    
    <!-- Приветствие -->
    <tr>
        <td align="center" style="padding: 0 20px 20px; font-size: 22px; font-weight: bold; color: #333;">
            Привет, {{ name }}!
        </td>
    </tr>
    
    <tr>
        <td align="center" style="padding: 0 20px 30px; font-size: 16px; line-height: 1.6; color: #555;">
            Рады приветствовать тебя в дружной команде PROTEGO!
        </td>
    </tr>
    
    <!-- Блок с данными -->
    <tr>
        <td style="padding: 25px; background: #f8f9fa; border-radius: 8px; border: 1px solid #e0e0e0;">
            <table width="100%" border="0" cellspacing="0" cellpadding="0">
                <tr>
                    <td style="padding: 8px 0; font-size: 15px;">
                        <strong>Имя пользователя:</strong> {{ username }}
                    </td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; font-size: 15px;">
                        <strong>Пароль:</strong> {{ password }}
                    </td>
                </tr>
            </table>
        </td>
    </tr>
    
    <!-- Подпись -->
    <tr>
        <td align="center" style="padding: 30px 20px 0; font-size: 16px; color: #555;">
            Приятной работы!
        </td>
    </tr>
</table>
{% endblock %}